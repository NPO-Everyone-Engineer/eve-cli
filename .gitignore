# Python
*.pyc
__pycache__/
*.pyo
*.egg-info/
dist/
build/

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Node
node_modules/

# Secrets - NEVER commit these
.env
.env.*
*credentials*
*secret*
*api_key*
*.pem
*.key

# Claude Code
.claude/

# qwen3.5 rules
.qwen/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# vibe-local RAG index (local, user-specific — not for version control)
.vibe/rag/

# EvE CLI local config (project-specific commands, hooks, memory — user-defined, never commit)
.eve-cli/
# Default template skills are distributed with the project (exception to above)
!.eve-cli/skills/
!.eve-cli/skills/*.md

# Local test artifacts
tests/*.log
tests/__pycache__/

# Generated reports (output of dev/ scripts — never commit)
dev/reports/

# Dev notes
make.md

# Markdown docs
*.md
!README.md
!docs/*.md

# Docs
00_Docs/
