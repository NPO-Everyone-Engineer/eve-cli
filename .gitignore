# Python
*.pyc
__pycache__/
*.pyo
*.egg-info/
dist/
build/

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Node
node_modules/

# Secrets - NEVER commit these
.env
.env.*
*credentials*
*secret*
*api_key*
*.pem
*.key

# Claude Code
.claude/

# qwen3.5 rules
.qwen/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# vibe-local RAG index (local, user-specific — not for version control)
.vibe/rag/

# EvE CLI — sensitive / ephemeral / user-specific (never commit)
.eve-cli/channels/
.eve-cli/context/
.eve-cli/plans/
.eve-cli/kairos/
.eve-cli/config
.eve-cli/memory.json

# EvE CLI — team-shared config (track these)
# CLAUDE.md, rules/, skills/, agents/, hooks.json, mcp.json, kairos.json は追跡対象

# Local test artifacts
tests/*.log
tests/__pycache__/

# Generated reports (output of dev/ scripts — never commit)
dev/reports/

# Dev notes
make.md

# Markdown docs
*.md
!README.md
!docs/*.md
!.eve-cli/CLAUDE.md
!.eve-cli/rules/*.md
!.eve-cli/skills/*.md
!.eve-cli/commands/*.md
!.eve-cli/agents/*.md

# 00_Docs/ は開発者向けメモ（gitignore 対象）
00_Docs/
